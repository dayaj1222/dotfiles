# Zathura Configuration
# Catppuccin Mocha theme with recoloring

# Font settings
set font "JetBrains Mono Nerd Font 12"

# Enable recoloring with Catppuccin Mocha colors
set recolor true
set recolor-keephue true

# Catppuccin Mocha color palette
set recolor-lightcolor "#1e1e2e"
set recolor-darkcolor "#cdd6f4"
set default-bg "#1e1e2e"

# Completion menu colors
set completion-bg "#1e1e2e"
set completion-fg "#cdd6f4"
set completion-group-bg "#1e1e2e"
set completion-group-fg "#74c7ec"
set completion-highlight-bg "#74c7ec"
set completion-highlight-fg "#1e1e2e"

# Input bar and notifications
set inputbar-bg "#1e1e2e"
set inputbar-fg "#cdd6f4"
set notification-bg "#1e1e2e"
set notification-fg "#cdd6f4"
set notification-error-bg "#f38ba8"
set notification-error-fg "#cdd6f4"
set notification-warning-bg "#fab387"
set notification-warning-fg "#1e1e2e"

# Status bar and index
set statusbar-bg "#1e1e2e"
set statusbar-fg "#cdd6f4"
set index-bg "#1e1e2e"
set index-fg "#cdd6f4"
set index-active-bg "#cba6f7"
set index-active-fg "#1e1e2e"

# Loading indicator
set render-loading-bg "#1e1e2e"
set render-loading-fg "#cba6f7"

# UI preferences
set window-title-home-tilde true
set statusbar-basename true
set selection-clipboard clipboard
