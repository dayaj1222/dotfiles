## CAVA configuration with Pywal colors
## Save as: ~/.config/wal/templates/cava.config
## Will be generated to: ~/.cache/wal/cava.config

[general]

# Framerate
framerate = 60

# Autosens to adjust sensitivity
autosens = 1

# Number of bars (0 = auto, fill console)
bars = 0

# Bar width and spacing (characters)
bar_width = 2
bar_spacing = 1

# Smoothing and sensitivity
noise_reduction = 77

[input]

# Method for audio capture (pulse, pipewire, alsa, fifo, etc)
; method = pulse
; source = auto

[output]

# Output method: ncurses, noncurses (default), raw, noritake, sdl, sdl_glsl
method = noncurses

# Orientation: bottom (default), top, left, right, horizontal
orientation = bottom

# Visual channels: stereo (default), mono
channels = stereo

[color]

# Use gradient mode with colors from wallpaper
gradient = 1

# Gradient colors using Pywal ANSI palette
# These automatically update when you change wallpapers
gradient_color_1 = '#{color1.strip}'
gradient_color_2 = '#{color2.strip}'
gradient_color_3 = '#{color3.strip}'
gradient_color_4 = '#{color4.strip}'
gradient_color_5 = '#{color5.strip}'
gradient_color_6 = '#{color6.strip}'
gradient_color_7 = '#{color7.strip}'
gradient_color_8 = '#{color8.strip}'

# For terminal mode, you can also uncomment these:
# background = '{background}'
# foreground = '{foreground}'

[smoothing]

# Monstercat smoothing
monstercat = 0

# Waves effect
waves = 0
